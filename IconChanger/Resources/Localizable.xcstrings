    "Icons will be cached automatically when you apply them to apps": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Symbole werden automatisch zwischengespeichert, wenn Sie sie auf Apps anwenden"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los iconos se almacenarán en caché automáticamente cuando los aplique a las aplicaciones"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les icônes seront mises en cache automatiquement lorsque vous les appliquerez aux applications"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le icone verranno memorizzate automaticamente quando le applichi alle app"
          }
        },
