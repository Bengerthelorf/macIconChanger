    "Import will only add new items, never replace or remove existing ones.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Import fügt nur neue Elemente hinzu, vorhandene werden weder ersetzt noch entfernt."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La importación solo agregará nuevos elementos, nunca reemplazará ni eliminará los existentes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'importation ajoutera uniquement de nouveaux éléments, sans remplacer ni supprimer les existants."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'importazione aggiungerà solo nuovi elementi, non sostituirà né rimuoverà quelli esistenti."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "インポートは新しい項目の追加のみで、既存の項目を置換・削除しません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "가져오기는 새 항목만 추가하며 기존 항목을 대체하거나 제거하지 않습니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "A importação apenas adicionará novos itens, nunca substituirá ou removerá os existentes."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Импорт только добавит новые элементы, не заменяя и не удаляя существующие."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "匯入只會新增項目，唔會取代或刪除現有項目。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "导入只会添加新项目，不会替换或删除现有项目。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "匯入只會新增項目，不會取代或刪除現有項目。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Import voegt alleen nieuwe items toe, vervangt of verwijdert nooit bestaande items."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "İçe aktarma yalnızca yeni öğeler ekler, mevcut olanları asla değiştirmez veya kaldırmaz."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Import doda tylko nowe elementy, nigdy nie zastąpi ani nie usunie istniejących."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سيقوم الاستيراد بإضافة عناصر جديدة فقط، ولن يستبدل أو يزيل العناصر الموجودة."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การนำเข้าจะเพิ่มรายการใหม่เท่านั้น ไม่มีการแทนที่หรือลบรายการที่มีอยู่"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Nhập sẽ chỉ thêm mục mới, không bao giờ thay thế hoặc xóa mục hiện có."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Impor hanya akan menambahkan item baru, tidak pernah mengganti atau menghapus yang sudah ada."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Імпорт лише додасть нові елементи, ніколи не замінить і не видалить існуючі."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Import lägger bara till nya objekt, ersätter eller tar aldrig bort befintliga."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Import tilføjer kun nye elementer, erstatter eller fjerner aldrig eksisterende."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Import legger bare til nye elementer, erstatter eller fjerner aldri eksisterende."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tuonti lisää vain uusia kohteita, ei koskaan korvaa tai poista olemassa olevia."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Import pouze přidá nové položky, nikdy nenahradí ani neodstraní stávající."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Az importálás csak új elemeket ad hozzá, soha nem cseréli le vagy távolítja el a meglévőket."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Η εισαγωγή θα προσθέσει μόνο νέα στοιχεία, δεν θα αντικαταστήσει ή αφαιρέσει υπάρχοντα."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Importul va adăuga doar elemente noi, nu va înlocui sau elimina pe cele existente."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आयात केवल नए आइटम जोड़ेगा, मौजूदा आइटम को कभी नहीं बदलेगा या हटाएगा।"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Import hanya akan menambah item baharu, tidak pernah mengganti atau mengalih keluar yang sedia ada."
          }
        }
      }
    },
