    "IconChanger needs administrator privileges to change app icons.\nClick the button below and enter your password to complete setup.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "IconChanger benötigt Administratorrechte, um App-Symbole zu ändern.\nKlicken Sie auf die Schaltfläche unten und geben Sie Ihr Passwort ein, um die Einrichtung abzuschließen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "IconChanger necesita privilegios de administrador para cambiar los iconos de las aplicaciones.\nHaga clic en el botón de abajo e ingrese su contraseña para completar la configuración."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "IconChanger a besoin des privilèges administrateur pour modifier les icônes des apps.\nCliquez sur le bouton ci-dessous et entrez votre mot de passe pour terminer la configuration."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "IconChanger necessita di privilegi di amministratore per cambiare le icone delle app.\nFai clic sul pulsante qui sotto e inserisci la password per completare la configurazione."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "IconChanger はアプリアイコンの変更に管理者権限が必要です。\n下のボタンをクリックしてパスワードを入力し、設定を完了してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "IconChanger는 앱 아이콘을 변경하려면 관리자 권한이 필요합니다.\n아래 버튼을 클릭하고 비밀번호를 입력하여 설정을 완료하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "IconChanger precisa de privilégios de administrador para alterar os ícones dos aplicativos.\nClique no botão abaixo e insira sua senha para concluir a configuração."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "IconChanger требует прав администратора для изменения значков приложений.\nНажмите кнопку ниже и введите пароль для завершения настройки."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "IconChanger 需要管理員權限來更改應用程式圖示。\n點擊下方按鈕並輸入密碼以完成設定。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "IconChanger 需要管理员权限来更改应用图标。\n点击下方按钮并输入密码以完成设置。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "IconChanger 需要管理員權限來更改應用程式圖示。\n點擊下方按鈕並輸入密碼以完成設定。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "IconChanger heeft beheerdersbevoegdheden nodig om app-pictogrammen te wijzigen.\nKlik op de onderstaande knop en voer uw wachtwoord in om de installatie te voltooien."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "IconChanger, uygulama simgelerini değiştirmek için yönetici ayrıcalıklarına ihtiyaç duyar.\nKurulumu tamamlamak için aşağıdaki düğmeye tıklayın ve parolanızı girin."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "IconChanger wymaga uprawnień administratora do zmiany ikon aplikacji.\nKliknij poniższy przycisk i wprowadź hasło, aby zakończyć konfigurację."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يحتاج IconChanger إلى صلاحيات المسؤول لتغيير أيقونات التطبيقات.\nانقر على الزر أدناه وأدخل كلمة المرور لإكمال الإعداد."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "IconChanger ต้องการสิทธิ์ผู้ดูแลระบบเพื่อเปลี่ยนไอคอนแอป\nคลิกปุ่มด้านล่างและป้อนรหัสผ่านเพื่อเสร็จสิ้นการตั้งค่า"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "IconChanger cần quyền quản trị viên để thay đổi biểu tượng ứng dụng.\nNhấn nút bên dưới và nhập mật khẩu để hoàn tất cài đặt."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "IconChanger memerlukan hak administrator untuk mengubah ikon aplikasi.\nKlik tombol di bawah dan masukkan kata sandi Anda untuk menyelesaikan pengaturan."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "IconChanger потребує прав адміністратора для зміни іконок додатків.\nНатисніть кнопку нижче та введіть пароль, щоб завершити налаштування."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "IconChanger behöver administratörsbehörigheter för att ändra appikoner.\nKlicka på knappen nedan och ange ditt lösenord för att slutföra installationen."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "IconChanger har brug for administratorrettigheder for at ændre app-ikoner.\nKlik på knappen nedenfor, og indtast din adgangskode for at fuldføre opsætningen."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "IconChanger trenger administratorrettigheter for å endre appikoner.\nKlikk på knappen nedenfor og skriv inn passordet ditt for å fullføre oppsettet."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "IconChanger tarvitsee järjestelmänvalvojan oikeudet sovelluskuvakkeiden vaihtamiseen.\nNapsauta alla olevaa painiketta ja anna salasanasi viimeistelläksesi asennuksen."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "IconChanger potřebuje oprávnění správce ke změně ikon aplikací.\nKlikněte na tlačítko níže a zadejte heslo pro dokončení nastavení."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Az IconChanger rendszergazdai jogosultságokat igényel az alkalmazásikonok módosításához.\nKattintson az alábbi gombra, és adja meg jelszavát a beállítás befejezéséhez."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Το IconChanger χρειάζεται δικαιώματα διαχειριστή για να αλλάξει τα εικονίδια εφαρμογών.\nΚάντε κλικ στο παρακάτω κουμπί και εισάγετε τον κωδικό σας για να ολοκληρωθεί η εγκατάσταση."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "IconChanger necesită privilegii de administrator pentru a schimba pictogramele aplicațiilor.\nFaceți clic pe butonul de mai jos și introduceți parola pentru a finaliza configurarea."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "IconChanger को ऐप आइकन बदलने के लिए व्यवस्थापक विशेषाधिकारों की आवश्यकता है।\nसेटअप पूरा करने के लिए नीचे दिए गए बटन पर क्लिक करें और अपना पासवर्ड दर्ज करें।"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "IconChanger memerlukan keistimewaan pentadbir untuk menukar ikon apl.\nKlik butang di bawah dan masukkan kata laluan anda untuk melengkapkan persediaan."
          }
        }
      }
    },
    "IconChanger needs to be visible in either the menu bar or the dock when running in the background.": {
      "comment": "Alert body",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "IconChanger muss entweder in der Menüleiste oder im Dock sichtbar sein, wenn es im Hintergrund läuft."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "IconChanger debe ser visible en la barra de menús o en el dock cuando se ejecuta en segundo plano."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "IconChanger doit être visible dans la barre des menus ou le Dock lorsqu'il s'exécute en tâche de fond."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "IconChanger deve essere visibile nella barra dei menu o nel dock durante l'esecuzione in background."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "バックグラウンドで実行中は、IconChangerはメニューバーまたはDockに表示される必要があります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "백그라운드에서 실행할 때 IconChanger는 메뉴 바 또는 Dock에 표시되어야 합니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "IconChanger precisa estar visível na barra de menus ou no dock ao executar em segundo plano."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "IconChanger должен быть виден в строке меню или в доке при работе в фоне."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "在背景執行時，IconChanger 需要在選單列或 Dock 中顯示。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在后台运行时，IconChanger 需要在菜单栏或程序坞中可见。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在背景執行時，IconChanger 需要在選單列或 Dock 中顯示。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "IconChanger moet zichtbaar zijn in de menubalk of het Dock wanneer het op de achtergrond wordt uitgevoerd."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "IconChanger, arka planda çalışırken menü çubuğunda veya dock'ta görünür olmalıdır."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "IconChanger musi być widoczny na pasku menu lub w Docku podczas pracy w tle."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يجب أن يكون IconChanger مرئيًا في شريط القوائم أو شريط المهام عند التشغيل في الخلفية."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "IconChanger ต้องแสดงในแถบเมนูหรือ Dock เมื่อทำงานในพื้นหลัง"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "IconChanger cần hiển thị ở thanh menu hoặc dock khi chạy nền."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "IconChanger perlu terlihat di bilah menu atau dock saat berjalan di latar belakang."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "IconChanger повинен бути видимим у рядку меню або в Dock при роботі у фоні."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "IconChanger måste vara synlig i menyraden eller dockan när den körs i bakgrunden."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "IconChanger skal være synlig i menulinjen eller docken, når den kører i baggrunden."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "IconChanger må være synlig i menylinjen eller docken når den kjører i bakgrunnen."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "IconChangerin on oltava näkyvissä valikkorivissä tai Dockissa taustalla käytettäessä."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "IconChanger musí být viditelný v panelu nabídek nebo v Docku, když běží na pozadí."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Az IconChangernek láthatónak kell lennie a menüsorban vagy a Dockban, ha a háttérben fut."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Το IconChanger πρέπει να είναι ορατό στη γραμμή μενού ή στο dock όταν εκτελείται στο παρασκήνιο."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "IconChanger trebuie să fie vizibil în bara de meniu sau în dock când rulează în fundal."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पृष्ठभूमि में चलते समय IconChanger को मेनू बार या डॉक में दिखाई देना चाहिए।"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "IconChanger perlu kelihatan di bar menu atau dok semasa berjalan di latar belakang."
          }
        }
      }
    },
