    "All cached app icons have been successfully restored.": {
      "comment": "Notification body",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle zwischengespeicherten App-Symbole wurden erfolgreich wiederhergestellt."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Todos los iconos de aplicaciones en caché han sido restaurados correctamente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Toutes les icônes d'applications en cache ont été restaurées avec succès."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tutte le icone delle app memorizzate sono state ripristinate con successo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "キャッシュされたすべてのアプリアイコンが正常に復元されました。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "모든 캐시된 앱 아이콘이 성공적으로 복원되었습니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Todos os ícones de aplicativos em cache foram restaurados com sucesso."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Все кэшированные значки приложений успешно восстановлены."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "所有快取的應用程式圖像已成功回復。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "所有缓存的应用图标已成功恢复。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "所有快取的 App 圖像已成功回復。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle opgeslagen app-pictogrammen zijn succesvol hersteld."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tüm önbelleğe alınmış uygulama simgeleri başarıyla geri yüklendi."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wszystkie zapisane ikony aplikacji zostały pomyślnie przywrócone."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تمت استعادة جميع أيقونات التطبيقات المخزنة مؤقتًا بنجاح."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ไอคอนแอปที่แคชไว้ทั้งหมดถูกกู้คืนเรียบร้อยแล้ว"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tất cả biểu tượng ứng dụng đã lưu đã được khôi phục thành công."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Semua ikon aplikasi yang di-cache telah berhasil dipulihkan."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Усі кешовані іконки додатків успішно відновлені."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Alla cachade appikoner har återställts."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle cachelagrede app-ikoner er blevet gendannet."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle bufrede appikoner har blitt gjenopprettet."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kaikki välimuistissa olevat sovelluskuvakkeet on palautettu onnistuneesti."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Všechny uložené ikony aplikací byly úspěšně obnoveny."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Az összes gyorsítótárazott alkalmazásikon sikeresen visszaállítva."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Όλα τα αποθηκευμένα εικονίδια εφαρμογών αποκαταστάθηκαν επιτυχώς."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Toate pictogramele aplicațiilor din cache au fost restaurate cu succes."
          }
        },
        "hi": {
          "stringUnit": {
