    "helper_files_missing_message_format" : {
      "comment" : "Message shown when helper files are missing. %@ is the list of files.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die folgenden erforderlichen Hilfsdateien konnten nicht gefunden oder kopiert werden:\n\n%@\n\nStellen Sie sicher, dass die App Schreibrechte für ihr Support-Verzeichnis (~/.iconchanger) hat, und versuchen Sie, die Anwendung neu zu starten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The following required helper files could not be found or copied:\n\n%@\n\nPlease ensure the app has permissions to write to its support directory (~/.iconchanger) and try restarting the application."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los siguientes archivos auxiliares requeridos no se pudieron encontrar o copiar:\n\n%@\n\nAsegúrese de que la aplicación tiene permisos para escribir en su directorio de soporte (~/.iconchanger) e intente reiniciar la aplicación."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les fichiers d'aide requis suivants n'ont pas pu être trouvés ou copiés :\n\n%@\n\nVeuillez vous assurer que l'application dispose des autorisations d'écriture pour son répertoire de support (~/.iconchanger) et essayez de redémarrer l'application."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "I seguenti file di supporto necessari non sono stati trovati o copiati:\n\n%@\n\nAssicurati che l'app abbia i permessi per scrivere nella sua directory di supporto (~/.iconchanger) e prova a riavviare l'applicazione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "以下の必要なヘルパーファイルが見つからないか、コピーできませんでした：\n\n%@\n\nアプリケーションがそのサポートディレクトリ（~/.iconchanger）への書き込み権限を持っていることを確認し、アプリケーションを再起動してみてください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "helper_files_missing_message_format"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Os seguintes arquivos auxiliares necessários não puderam ser encontrados ou copiados:\n\n%@\n\nCertifique-se de que o aplicativo tem permissões para escrever em seu diretório de suporte (~/.iconchanger) e tente reiniciar o aplicativo."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Следующие необходимые вспомогательные файлы не найдены или не скопированы:\n\n%@\n\nУбедитесь, что приложение имеет разрешение на запись в свой каталог поддержки (~/.iconchanger) и попробуйте перезапустить приложение."
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "無法找到或複製下列所需的輔助檔案：\n\n%@\n\n請確保應用程式對其支援目錄 (~/.iconchanger) 具有寫入權限，並嘗試重新啟動應用程式。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "无法找到或复制以下所需的辅助文件：\n\n%@\n\n请确保应用程序具有写入其支持目录 (~/.iconchanger) 的权限，并尝试重新启动应用程序。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "無法找到或複製下列所需的輔助檔案：\n\n%@\n\n請確保應用程式對其支援目錄 (~/.iconchanger) 具有寫入權限，並嘗試重新啟動應用程式。"
          }
        }
      }
    },
