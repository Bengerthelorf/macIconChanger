          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Значки будут автоматически кэшироваться при их применении к приложениям"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "將圖像套用到應用程式時會自動快取"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当你将图标应用于应用程序时，它们将被自动缓存"
