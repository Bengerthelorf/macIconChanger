    "Export your aliases and icon cache for backup or to use on another Mac.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Exportieren Sie Ihre Aliase und den Symbolcache als Backup oder zur Verwendung auf einem anderen Mac."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Exporte sus alias y caché de iconos para respaldo o para usar en otro Mac."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Exportez vos alias et cache d'icônes pour sauvegarde ou pour utiliser sur un autre Mac."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Esporta i tuoi alias e la cache delle icone per il backup o per l'uso su un altro Mac."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "エイリアスとアイコンキャッシュをバックアップまたは別の Mac で使用するためにエクスポートします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "백업하거나 다른 Mac에서 사용하기 위해 별칭과 아이콘 캐시를 내보냅니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Exporte seus aliases e cache de ícones para backup ou para usar em outro Mac."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Экспортируйте псевдонимы и кэш значков для резервного копирования или использования на другом Mac."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "匯出別名和圖像快取，用於備份或在其他 Mac 上使用。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "导出别名和图标缓存，用于备份或在其他 Mac 上使用。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "匯出別名和圖像快取，用於備份或在其他 Mac 上使用。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Exporteer uw aliassen en pictogramcache voor back-up of om op een andere Mac te gebruiken."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yedekleme veya başka bir Mac'te kullanmak için takma adlarınızı ve simge önbelleğinizi dışa aktarın."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wyeksportuj aliasy i pamięć podręczną ikon do kopii zapasowej lub użycia na innym Macu."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "قم بتصدير الأسماء المستعارة وذاكرة التخزين المؤقت للأيقونات للنسخ الاحتياطي أو للاستخدام على جهاز Mac آخر."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ส่งออกนามแฝงและแคชไอคอนเพื่อสำรองข้อมูลหรือใช้บน Mac เครื่องอื่น"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Xuất bí danh và bộ nhớ đệm biểu tượng để sao lưu hoặc sử dụng trên máy Mac khác."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Ekspor alias dan cache ikon Anda untuk cadangan atau untuk digunakan di Mac lain."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Експортуйте свої псевдоніми та кеш іконок для резервного копіювання або використання на іншому Mac."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Exportera dina alias och ikoncache för säkerhetskopiering eller för att använda på en annan Mac."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Eksportér dine aliasser og ikoncache til backup eller til brug på en anden Mac."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Eksporter aliasene og ikonbufferen din for sikkerhetskopiering eller bruk på en annen Mac."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Vie aliakset ja kuvakevälimuisti varmuuskopiointia tai toisella Macilla käyttöä varten."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Exportujte své aliasy a mezipaměť ikon pro zálohu nebo pro použití na jiném Macu."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Exportálja álneveit és ikon-gyorsítótárát biztonsági mentéshez vagy másik Macen való használathoz."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Εξάγετε τα ψευδώνυμά σας και την προσωρινή μνήμη εικονιδίων για αντίγραφο ασφαλείας ή χρήση σε άλλο Mac."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Exportați aliasurile și cache-ul de pictograme pentru backup sau pentru utilizare pe un alt Mac."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "बैकअप के लिए या किसी अन्य Mac पर उपयोग करने के लिए अपने उपनाम और आइकन कैश निर्यात करें।"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Eksport alias dan cache ikon anda untuk sandaran atau untuk digunakan pada Mac lain."
          }
        }
      }
    },
