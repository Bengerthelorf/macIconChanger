    "Helper Files Missing" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Helper Files Missing"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fichiers d'aide manquants"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ヘルパーファイルが見つかりません"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "辅助文件缺失"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "輔助檔案遺失"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "輔助檔案遺失"
          }
        }
      }
    },
    "helper_files_missing_instructions_format" : {
      "comment" : "Instructions when helper files are missing. First %@ is list of files, second %@ is expected path.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The following helper files required by IconChanger seem to be missing or couldn't be copied:\n\n%@\n\nExpected location: %@\n\nPlease try the following:\n1. Ensure IconChanger has write permissions for the `~/.iconchanger` directory.\n2. Restart IconChanger.\n3. If the problem persists, try reinstalling the application."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les fichiers d'aide suivants requis par IconChanger semblent manquants ou n'ont pas pu être copiés :\n\n%@\n\nEmplacement attendu : %@\n\nVeuillez essayer ce qui suit :\n1. Assurez-vous qu'IconChanger dispose des autorisations d'écriture pour le répertoire `~/.iconchanger`.\n2. Redémarrez IconChanger.\n3. Si le problème persiste, essayez de réinstaller l'application."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "IconChangerに必要な以下のヘルパーファイルが見つからないか、コピーできなかったようです：\n\n%@\n\n予期される場所：%@\n\n以下をお試しください：\n1. IconChangerが `~/.iconchanger` ディレクトリへの書き込み権限を持っていることを確認します。\n2. IconChangerを再起動します。\n3. 問題が解決しない場合は、アプリケーションを再インストールしてみてください。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "IconChanger 所需的以下辅助文件似乎缺失或无法复制：\n\n%@\n\n预期位置：%@\n\n请尝试以下操作：\n1. 确保 IconChanger 对 `~/.iconchanger` 目录具有写入权限。\n2. 重新启动 IconChanger。\n3. 如果问题仍然存在，请尝试重新安装应用程序。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "IconChanger 所需的下列輔助檔案似乎遺失或無法複製：\n\n%@\n\n預期位置：%@\n\n請嘗試下列操作：\n1. 確保 IconChanger 對 `~/.iconchanger` 目錄具有寫入權限。\n2. 重新啟動 IconChanger。\n3. 如果問題持續存在，請嘗試重新安裝應用程式。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "IconChanger 所需的下列輔助檔案似乎遺失或無法複製：\n\n%@\n\n預期位置：%@\n\n請嘗試下列操作：\n1. 確保 IconChanger 對 `~/.iconchanger` 目錄具有寫入權限。\n2. 重新啟動 IconChanger。\n3. 如果問題持續存在，請嘗試重新安裝應用程式。"
          }
        }
      }
    },
    "helper_files_missing_message_format" : {
      "comment" : "Message shown when helper files are missing. %@ is the list of files.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The following required helper files could not be found or copied:\n\n%@\n\nPlease ensure the app has permissions to write to its support directory (~/.iconchanger) and try restarting the application."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les fichiers d'aide requis suivants n'ont pas pu être trouvés ou copiés :\n\n%@\n\nVeuillez vous assurer que l'application dispose des autorisations d'écriture pour son répertoire de support (~/.iconchanger) et essayez de redémarrer l'application."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "以下の必要なヘルパーファイルが見つからないか、コピーできませんでした：\n\n%@\n\nアプリケーションがそのサポートディレクトリ（~/.iconchanger）への書き込み権限を持っていることを確認し、アプリケーションを再起動してみてください。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "无法找到或复制以下所需的辅助文件：\n\n%@\n\n请确保应用程序具有写入其支持目录 (~/.iconchanger) 的权限，并尝试重新启动应用程序。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "無法找到或複製下列所需的輔助檔案：\n\n%@\n\n請確保應用程式對其支援目錄 (~/.iconchanger) 具有寫入權限，並嘗試重新啟動應用程式。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "無法找到或複製下列所需的輔助檔案：\n\n%@\n\n請確保應用程式對其支援目錄 (~/.iconchanger) 具有寫入權限，並嘗試重新啟動應用程式。"
          }
        }
      }
    },
