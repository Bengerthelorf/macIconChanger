          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Exportați aliasurile și cache-ul de pictograme pentru backup sau pentru utilizare pe un alt Mac."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Экспортируйте псевдонимы и кэш значков для резервного копирования или использования на другом Mac."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Exportera dina alias och ikoncache för säkerhetskopiering eller för att använda på en annan Mac."
          }
        },
        "th" : {
