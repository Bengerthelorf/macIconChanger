        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Όλες οι εφαρμογές έχουν ήδη προσαρμοσμένα εικονίδια ή δεν ήταν δυνατή η επεξεργασία τους."
