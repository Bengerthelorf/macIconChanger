    "IconChanger needs permission to run its helper script with administrator privileges to change icons.\nThis requires a manual configuration" : {
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "IconChanger a besoin de la permission pour exécuter son script d'aide avec les privilèges administrateur afin de modifier les icônes.\nCela nécessite une configuration manuelle"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "IconChangerがヘルパースクリプトを管理者権限で実行してアイコンを変更するには権限が必要です。\nこれには手動での設定が必要です"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "IconChanger 需要权限以管理员身份运行其辅助脚本来更改图标。\n这需要手动配置"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "IconChanger 需要權限以管理者身份執行其輔助程式碼來變更圖示。\n這需要手動設定"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "IconChanger 需要權限以管理員身份執行其輔助程式碼來更改圖示。\n這需要手動設定"
          }
        }
      }
    },
    "IconChanger needs to be visible in either the menu bar or the dock when running in the background." : {
