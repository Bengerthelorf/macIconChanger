    "Enter a custom interval (in hours) for automatic icon restoration.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Geben Sie ein benutzerdefiniertes Intervall (in Stunden) für die automatische Symbolwiederherstellung ein."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ingrese un intervalo personalizado (en horas) para la restauración automática de iconos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Entrez un intervalle personnalisé (en heures) pour la restauration automatique des icônes."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Inserisci un intervallo personalizzato (in ore) per il ripristino automatico delle icone."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アイコン自動復元のためのカスタム間隔（時間単位）を入力してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "자동 아이콘 복원을 위한 사용자 지정 간격(시간)을 입력하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Insira um intervalo personalizado (em horas) para a restauração automática de ícones."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Введите пользовательский интервал (в часах) для автоматического восстановления значков."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "輸入自動圖像回復的自訂間隔（以小時為單位）。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "输入自动图标恢复的自定义间隔（以小时为单位）。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "輸入自動圖像回復的自訂間隔（以小時為單位）。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Voer een aangepast interval (in uren) in voor automatisch pictogramherstel."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Otomatik simge geri yükleme için özel bir aralık (saat cinsinden) girin."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wprowadź niestandardowy interwał (w godzinach) automatycznego przywracania ikon."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أدخل فترة مخصصة (بالساعات) لاستعادة الأيقونات تلقائيًا."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ป้อนช่วงเวลาที่กำหนดเอง (เป็นชั่วโมง) สำหรับการกู้คืนไอคอนอัตโนมัติ"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Nhập khoảng thời gian tùy chỉnh (tính bằng giờ) để khôi phục biểu tượng tự động."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Masukkan interval kustom (dalam jam) untuk pemulihan ikon otomatis."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Введіть користувацький інтервал (у годинах) для автоматичного відновлення іконок."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Ange ett anpassat intervall (i timmar) för automatisk ikonåterställning."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Angiv et brugerdefineret interval (i timer) for automatisk ikongendannelse."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Angi et tilpasset intervall (i timer) for automatisk ikongjenoppretting."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Syötä mukautettu aikaväli (tunteina) automaattista kuvakkeiden palautusta varten."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Zadejte vlastní interval (v hodinách) pro automatické obnovení ikon."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Adjon meg egyéni időközt (órákban) az automatikus ikon-visszaállításhoz."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Εισάγετε ένα προσαρμοσμένο διάστημα (σε ώρες) για αυτόματη επαναφορά εικονιδίων."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Introduceți un interval personalizat (în ore) pentru restaurarea automată a pictogramelor."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "स्वचालित आइकन पुनर्स्थापना के लिए एक कस्टम अंतराल (घंटों में) दर्ज करें।"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Masukkan selang tersuai (dalam jam) untuk pemulihan ikon automatik."
          }
        }
      }
    },
    "Enter a custom interval (in minutes) for checking app updates.": {
      "localizations": {
        "de": {
