    "Are you sure you want to clear all %lld cached icons?": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sind Sie sicher, dass Sie alle %lld zwischengespeicherten Symbole löschen möchten?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Está seguro de que desea borrar todos los %lld iconos en caché?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Voulez-vous vraiment supprimer les %lld icônes en cache ?"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sei sicuro di voler cancellare tutte le %lld icone memorizzate?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "キャッシュされた %lld 個のアイコンをすべて削除しますか？"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "캐시된 아이콘 %lld개를 모두 삭제하시겠습니까?"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Tem certeza de que deseja limpar todos os %lld ícones em cache?"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вы уверены, что хотите удалить все %lld кэшированных значков?"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "確定要清除全部 %lld 個快取圖像嗎？"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "确定要清除全部 %lld 个缓存图标吗？"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "確定要清除全部 %lld 個快取圖像嗎？"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Weet u zeker dat u alle %lld opgeslagen pictogrammen wilt wissen?"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tüm %lld önbelleğe alınmış simgeyi silmek istediğinizden emin misiniz?"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Czy na pewno chcesz usunąć wszystkie %lld zapisane ikony?"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "هل أنت متأكد أنك تريد مسح جميع الأيقونات المخزنة مؤقتًا البالغ عددها %lld؟"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "คุณแน่ใจหรือไม่ว่าต้องการล้างไอคอนที่แคชไว้ทั้งหมด %lld รายการ?"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Bạn có chắc muốn xóa tất cả %lld biểu tượng đã lưu?"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Apakah Anda yakin ingin menghapus semua %lld ikon yang di-cache?"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ви впевнені, що хочете очистити всі %lld кешованих іконок?"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Är du säker på att du vill rensa alla %lld cachade ikoner?"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Er du sikker på, at du vil rydde alle %lld cachelagrede ikoner?"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Er du sikker på at du vil slette alle %lld bufrede ikoner?"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Haluatko varmasti tyhjentää kaikki %lld välimuistissa olevaa kuvaketta?"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Opravdu chcete vymazat všech %lld uložených ikon?"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Biztosan törölni szeretné mind a %lld gyorsítótárazott ikont?"
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Είστε βέβαιοι ότι θέλετε να διαγράψετε όλα τα %lld αποθηκευμένα εικονίδια;"
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Sigur doriți să ștergeți toate cele %lld pictograme din cache?"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "क्या आप वाकई सभी %lld कैश्ड आइकन साफ़ करना चाहते हैं?"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Adakah anda pasti mahu mengosongkan semua %lld ikon yang dicache?"
          }
        }
      }
    },
    "Are you sure you want to remove %lld selected icon(s) from the cache?": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sind Sie sicher, dass Sie %lld ausgewählte(s) Symbol(e) aus dem Cache entfernen möchten?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Está seguro de que desea eliminar %lld icono(s) seleccionado(s) del caché?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Voulez-vous vraiment supprimer %lld icône(s) sélectionnée(s) du cache ?"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sei sicuro di voler rimuovere %lld icona/e selezionata/e dalla cache?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "選択した %lld 個のアイコンをキャッシュから削除しますか？"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "선택한 아이콘 %lld개를 캐시에서 제거하시겠습니까?"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Tem certeza de que deseja remover %lld ícone(s) selecionado(s) do cache?"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вы уверены, что хотите удалить %lld выбранных значков из кэша?"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "確定要從快取中移除選取的 %lld 個圖像嗎？"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "确定要从缓存中移除选中的 %lld 个图标吗？"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "確定要從快取中移除選取的 %lld 個圖像嗎？"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Weet u zeker dat u %lld geselecteerde pictogram(men) uit de cache wilt verwijderen?"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld seçili simgeyi önbellekten kaldırmak istediğinizden emin misiniz?"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Czy na pewno chcesz usunąć %lld wybranych ikon z pamięci podręcznej?"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "هل أنت متأكد أنك تريد إزالة %lld أيقونات مختارة من ذاكرة التخزين المؤقت؟"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "คุณแน่ใจหรือไม่ว่าต้องการลบ %lld ไอคอนที่เลือกออกจากแคช?"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Bạn có chắc muốn xóa %lld biểu tượng đã chọn khỏi bộ nhớ đệm?"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Apakah Anda yakin ingin menghapus %lld ikon terpilih dari cache?"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ви впевнені, що хочете видалити %lld вибраних іконок з кешу?"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Är du säker på att du vill ta bort %lld valda ikoner från cachen?"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Er du sikker på, at du vil fjerne %lld valgte ikon(er) fra cachen?"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Er du sikker på at du vil fjerne %lld valgte ikon(er) fra bufferen?"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Haluatko varmasti poistaa %lld valittua kuvaketta välimuistista?"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Opravdu chcete odebrat %lld vybraných ikon z mezipaměti?"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Biztosan el szeretné távolítani a kiválasztott %lld ikont a gyorsítótárból?"
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Είστε βέβαιοι ότι θέλετε να αφαιρέσετε %lld επιλεγμένα εικονίδια από την προσωρινή μνήμη;"
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Sigur doriți să eliminați %lld pictograme selectate din cache?"
          }
        },
        "hi": {
