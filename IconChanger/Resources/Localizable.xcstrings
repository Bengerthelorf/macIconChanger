    "%lld updated app(s) had their custom icons restored." : {
      "comment" : "Notification body",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld aktualisierte App(s) hatten ihre benutzerdefinierten Symbole wiederhergestellt."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld aplicación(es) actualizada(s) tuvieron sus iconos personalizados restaurados."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld application(s) mise(s) à jour ont eu leurs icônes personnalisées restaurées."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld app aggiornata/e hanno avuto le icone personalizzate ripristinate."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld 個の更新されたアプリのカスタムアイコンが復元されました。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld개의 업데이트된 앱에 사용자 지정 아이콘이 복원되었습니다."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld aplicativo(s) atualizado(s) tiveram seus ícones personalizados restaurados."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "У %lld обновлённых приложений восстановлены пользовательские значки."
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld 個已更新的應用程式已回復其自訂圖像。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld 个已更新的应用已恢复其自定义图标。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld 個已更新的 App 已回復其自訂圖像。"
          }
        }
      }
    },
