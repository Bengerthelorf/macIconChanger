        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "1. /Applicationsへのアクセスを要求するダイアログが表示されます"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
