{
  "sourceLanguage" : "en",
  "strings" : {
    "\"Start Hidden\" requires \"Run in Background\" to be enabled." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"البدء مخفيًا\" يتطلب تفعيل \"التشغيل في الخلفية\"."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Skrytý start\" vyžaduje povolení \"Spustit na pozadí\"."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Start skjult\" kræver, at \"Kør i baggrunden\" er aktiveret."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Versteckt starten\" erfordert, dass \"Im Hintergrund ausführen\" aktiviert ist."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Η \"Κρυφή εκκίνηση\" απαιτεί την ενεργοποίηση της \"Εκτέλεσης στο παρασκήνιο\"."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Iniciar oculto\" requiere que \"Ejecutar en segundo plano\" esté activado."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Käynnistä piilotettuna\" vaatii, että \"Suorita taustalla\" on käytössä."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "« Démarrer en arrière-plan » nécessite l’activation de « Exécuter en arrière-plan »."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"छिपकर शुरू करें\" के लिए \"पृष्ठभूमि में चलाएं\" सक्षम होना आवश्यक है।"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Rejtett indítás\" megköveteli a \"Futtatás a háttérben\" engedélyezését."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Mulai Tersembunyi\" memerlukan \"Jalankan di Latar Belakang\" diaktifkan."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Avvio nascosto\" richiede che \"Esegui in background\" sia attivato."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「バックグラウンドで起動」するには「バックグラウンドで実行」を有効にする必要があります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"숨김 상태로 시작\"을 사용하려면 \"백그라운드에서 실행\"을 활성화해야 합니다."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Mula Tersembunyi\" memerlukan \"Jalankan di Latar Belakang\" diaktifkan."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Start skjult\" krever at \"Kjør i bakgrunnen\" er aktivert."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Verborgen starten\" vereist dat \"Op de achtergrond uitvoeren\" is ingeschakeld."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Ukryty start\" wymaga włączenia \"Uruchom w tle\"."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Iniciar oculto\" requer que \"Executar em segundo plano\" esteja ativado."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Pornire ascunsă\" necesită activarea \"Rulare în fundal\"."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Скрытый запуск\" требует включения \"Работа в фоне\"."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Starta dold\" kräver att \"Kör i bakgrunden\" är aktiverat."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"เริ่มแบบซ่อน\" ต้องเปิดใช้งาน \"ทำงานในพื้นหลัง\""
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Gizli Başlat\" için \"Arka Planda Çalıştır\" etkinleştirilmelidir."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Прихований запуск\" потребує ввімкнення \"Робота у фоні\"."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Khởi động ẩn\" yêu cầu bật \"Chạy nền\"."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“后台启动”需要启用“在后台运行”。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“背景啟動”需要啟用“在背景執行”。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“背景啟動”需要啟用“在背景執行”。"
          }
        }
      }
    },
