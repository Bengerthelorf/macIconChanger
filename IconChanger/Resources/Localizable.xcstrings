    "All apps already have custom icons or could not be processed." : {
      "comment" : "Alert body",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "جميع التطبيقات لديها بالفعل أيقونات مخصصة أو لا يمكن معالجتها."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Všechny aplikace již mají vlastní ikony nebo je nelze zpracovat."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alle apps har allerede tilpassede ikoner eller kunne ikke behandles."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alle Apps haben bereits benutzerdefinierte Symbole oder konnten nicht verarbeitet werden."
