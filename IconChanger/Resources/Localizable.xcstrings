    "%lld updated app(s) had their custom icons restored.": {
      "comment": "Notification body",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld aktualisierte App(s) hatten ihre benutzerdefinierten Symbole wiederhergestellt."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld aplicación(es) actualizada(s) tuvieron sus iconos personalizados restaurados."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld application(s) mise(s) à jour ont eu leurs icônes personnalisées restaurées."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld app aggiornata/e hanno avuto le icone personalizzate ripristinate."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld 個の更新されたアプリのカスタムアイコンが復元されました。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld개의 업데이트된 앱에 사용자 지정 아이콘이 복원되었습니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld aplicativo(s) atualizado(s) tiveram seus ícones personalizados restaurados."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "У %lld обновлённых приложений восстановлены пользовательские значки."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld 個已更新的應用程式已回復其自訂圖像。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld 个已更新的应用已恢复其自定义图标。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld 個已更新的 App 已回復其自訂圖像。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld bijgewerkte app(s) hebben hun aangepaste pictogrammen hersteld."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld güncellenen uygulamanın özel simgeleri geri yüklendi."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld zaktualizowanych aplikacji przywróciło niestandardowe ikony."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تمت استعادة الأيقونات المخصصة لـ %lld تطبيقات محدثة."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld แอปที่อัปเดตได้กู้คืนไอคอนที่กำหนดเองแล้ว"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld ứng dụng đã cập nhật đã khôi phục biểu tượng tùy chỉnh."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld aplikasi yang diperbarui telah memulihkan ikon kustomnya."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld оновлених додатків відновили свої іконки."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld uppdaterade appar har fått sina anpassade ikoner återställda."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld opdaterede apps har fået deres brugerdefinerede ikoner gendannet."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld oppdaterte apper har fått sine tilpassede ikoner gjenopprettet."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld päivitetyn sovelluksen mukautetut kuvakkeet palautettiin."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld aktualizovaným aplikacím byly obnoveny vlastní ikony."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld frissített alkalmazás egyéni ikonjai visszaállítva."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld ενημερωμένες εφαρμογές επαναφέρθηκαν τα προσαρμοσμένα εικονίδιά τους."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld aplicații actualizate au avut pictogramele personalizate restaurate."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld अपडेट किए गए ऐप्स के कस्टम आइकन पुनर्स्थापित किए गए।"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld apl yang dikemas kini telah memulihkan ikon tersuai mereka."
          }
        }
      }
    },
