        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "匯入只會新增項目，唔會取代或刪除現有項目。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "가져오기는 새 항목만 추가하며 기존 항목을 대체하거나 제거하지 않습니다."
          }
        }
      }
    },
