    "%lld updated app(s) had their custom icons restored." : {
      "comment" : "Notification body",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld application(s) mise(s) à jour ont eu leurs icônes personnalisées restaurées."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld 個の更新されたアプリのカスタムアイコンが復元されました。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld 个已更新的应用已恢复其自定义图标。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld 個已更新的 App 已回復其自訂圖像。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld 個已更新的應用程式已回復其自訂圖像。"
          }
        }
      }
    },
