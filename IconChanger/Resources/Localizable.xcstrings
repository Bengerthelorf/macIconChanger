        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "IconChanger CLI टूल कॉन्फ़िगरेशन आयात और निर्यात करने के लिए कमांड लाइन एक्सेस प्रदान करता है।"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Alat CLI IconChanger menyediakan akses baris perintah untuk mengimport dan mengeksport konfigurasi."
          }
        }
      }
    },
    "The app will monitor your cached applications for updates and automatically restore their custom icons when updates are detected.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die App überwacht Ihre zwischengespeicherten Anwendungen auf Updates und stellt deren benutzerdefinierte Symbole automatisch wieder her."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La aplicación monitoreará sus aplicaciones en caché para detectar actualizaciones y restaurará automáticamente sus iconos personalizados."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'application surveillera les mises à jour de vos applications en cache et restaurera automatiquement leurs icônes personnalisées lorsque des mises à jour seront détectées."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'app monitorerà le applicazioni memorizzate per gli aggiornamenti e ripristinerà automaticamente le icone personalizzate."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アプリはキャッシュされたアプリケーションの更新を監視し、更新が検出されるとカスタムアイコンを自動的に復元します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "앱이 캐시된 응용 프로그램의 업데이트를 모니터링하고 업데이트가 감지되면 자동으로 사용자 지정 아이콘을 복원합니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O aplicativo monitorará seus aplicativos em cache para atualizações e restaurará automaticamente seus ícones personalizados."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Приложение будет отслеживать обновления кэшированных приложений и автоматически восстанавливать их пользовательские значки."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "應用程式會監視你快取的應用程式是否有更新，並在偵測到更新時自動回復其自訂圖像。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "该应用程序将监视您缓存的应用程序是否有更新，并在检测到更新时自动恢复其自定义图标。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "App 會監視你快取的應用程式是否有更新，並在偵測到更新時自動回復其自訂圖像。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De app controleert uw opgeslagen applicaties op updates en herstelt automatisch hun aangepaste pictogrammen wanneer updates worden gedetecteerd."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Uygulama, önbelleğe alınmış uygulamalarınızı güncellemeler için izleyecek ve güncellemeler algılandığında özel simgelerini otomatik olarak geri yükleyecektir."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Aplikacja będzie monitorować zapisane aplikacje pod kątem aktualizacji i automatycznie przywracać ich niestandardowe ikony po wykryciu aktualizacji."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سيراقب التطبيق تطبيقاتك المخزنة مؤقتًا بحثًا عن تحديثات ويستعيد تلقائيًا أيقوناتها المخصصة عند اكتشاف التحديثات."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "แอปจะตรวจสอบแอปพลิเคชันที่แคชไว้ของคุณเพื่อหาการอัปเดตและกู้คืนไอคอนที่กำหนดเองโดยอัตโนมัติเมื่อตรวจพบการอัปเดต"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Ứng dụng sẽ theo dõi các ứng dụng đã lưu để tìm bản cập nhật và tự động khôi phục biểu tượng tùy chỉnh khi phát hiện bản cập nhật."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Aplikasi akan memantau aplikasi yang di-cache untuk pembaruan dan secara otomatis memulihkan ikon kustomnya saat pembaruan terdeteksi."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Додаток буде відстежувати кешовані програми на наявність оновлень і автоматично відновлювати їхні іконки при виявленні оновлень."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Appen övervakar dina cachade applikationer för uppdateringar och återställer automatiskt deras anpassade ikoner när uppdateringar upptäcks."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Appen vil overvåge dine cachelagrede applikationer for opdateringer og automatisk gendanne deres brugerdefinerede ikoner, når opdateringer registreres."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Appen vil overvåke de bufrede applikasjonene dine for oppdateringer og automatisk gjenopprette deres tilpassede ikoner når oppdateringer oppdages."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Sovellus seuraa välimuistissa olevia sovelluksia päivitysten varalta ja palauttaa automaattisesti niiden mukautetut kuvakkeet päivitysten yhteydessä."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Aplikace bude sledovat vaše uložené aplikace pro aktualizace a automaticky obnoví jejich vlastní ikony při detekci aktualizací."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Az alkalmazás figyelni fogja a gyorsítótárazott alkalmazásokat frissítések szempontjából, és automatikusan visszaállítja az egyéni ikonjaikat frissítés észlelésekor."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Η εφαρμογή θα παρακολουθεί τις αποθηκευμένες εφαρμογές σας για ενημερώσεις και θα επαναφέρει αυτόματα τα προσαρμοσμένα εικονίδιά τους όταν εντοπιστούν ενημερώσεις."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Aplicația va monitoriza aplicațiile din cache pentru actualizări și va restaura automat pictogramele personalizate când sunt detectate actualizări."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ऐप आपके कैश्ड एप्लिकेशन की अपडेट के लिए निगरानी करेगा और अपडेट पाए जाने पर स्वचालित रूप से उनके कस्टम आइकन पुनर्स्थापित करेगा।"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Apl akan memantau aplikasi yang dicache anda untuk kemas kini dan secara automatik memulihkan ikon tersuai mereka apabila kemas kini dikesan."
          }
        }
      }
    },
    "The language has been changed. For the best experience, please restart the application.": {
      "comment": "Language alert message",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Sprache wurde geändert. Für die beste Erfahrung starten Sie die Anwendung bitte neu."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El idioma ha sido cambiado. Para una mejor experiencia, reinicie la aplicación."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La langue a été modifiée. Pour une meilleure expérience, veuillez redémarrer l'application."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La lingua è stata cambiata. Per la migliore esperienza, riavvia l'applicazione."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "言語が変更されました。最適な体験のために、アプリケーションを再起動してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "언어가 변경되었습니다. 최상의 경험을 위해 앱을 다시 시작하세요."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O idioma foi alterado. Para uma melhor experiência, reinicie o aplicativo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Язык был изменён. Для лучшего опыта перезапустите приложение."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "語言已更改。為獲得最佳體驗，請重新啟動應用程式。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "语言已更改。为了获得最佳体验，请重新启动应用程序。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "語言已更改。為獲得最佳體驗，請重新啟動應用程式。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De taal is gewijzigd. Herstart de applicatie voor de beste ervaring."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dil değiştirildi. En iyi deneyim için lütfen uygulamayı yeniden başlatın."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Język został zmieniony. Aby uzyskać najlepsze wrażenia, uruchom ponownie aplikację."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم تغيير اللغة. للحصول على أفضل تجربة، يرجى إعادة تشغيل التطبيق."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ภาษาถูกเปลี่ยนแล้ว เพื่อประสบการณ์ที่ดีที่สุด กรุณารีสตาร์ทแอปพลิเคชัน"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Ngôn ngữ đã được thay đổi. Để có trải nghiệm tốt nhất, vui lòng khởi động lại ứng dụng."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Bahasa telah diubah. Untuk pengalaman terbaik, silakan mulai ulang aplikasi."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Мову змінено. Для найкращого досвіду перезапустіть додаток."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Språket har ändrats. Starta om appen för bästa upplevelse."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Sproget er blevet ændret. For den bedste oplevelse bedes du genstarte programmet."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Språket er endret. For best opplevelse, vennligst start appen på nytt."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kieli on vaihdettu. Parhaan kokemuksen saamiseksi käynnistä sovellus uudelleen."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Jazyk byl změněn. Pro nejlepší zážitek restartujte aplikaci."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A nyelv megváltozott. A legjobb élmény érdekében indítsa újra az alkalmazást."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Η γλώσσα άλλαξε. Για την καλύτερη εμπειρία, επανεκκινήστε την εφαρμογή."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Limba a fost schimbată. Pentru cea mai bună experiență, reporniți aplicația."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "भाषा बदल दी गई है। सर्वोत्तम अनुभव के लिए, कृपया एप्लिकेशन को पुनः प्रारंभ करें।"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Bahasa telah ditukar. Untuk pengalaman terbaik, sila mulakan semula aplikasi."
          }
        }
      }
    },
    "This action cannot be undone. You will need to re-apply icons to cache them again.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese Aktion kann nicht rückgängig gemacht werden. Sie müssen Symbole erneut anwenden, um sie wieder zwischenzuspeichern."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta acción no se puede deshacer. Necesitará volver a aplicar los iconos para almacenarlos en caché nuevamente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette action est irréversible. Vous devrez réappliquer les icônes pour les remettre en cache."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questa azione non può essere annullata. Dovrai riapplicare le icone per memorizzarle di nuovo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この操作は取り消せません。アイコンを再度キャッシュするには再適用が必要です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 작업은 실행 취소할 수 없습니다. 다시 캐시하려면 아이콘을 다시 적용해야 합니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta ação não pode ser desfeita. Você precisará reaplicar os ícones para armazená-los em cache novamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Это действие нельзя отменить. Вам потребуется повторно применить значки для их кэширования."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "呢個操作冇得撤銷。需要重新套用圖像先可以再次快取。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此操作无法撤销。需要重新应用图标才能再次缓存。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "此操作無法撤銷。需要重新套用圖像才能再次快取。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Deze actie kan niet ongedaan worden gemaakt. U moet pictogrammen opnieuw toepassen om ze weer op te slaan."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu işlem geri alınamaz. Simgeleri yeniden önbelleğe almak için tekrar uygulamanız gerekecektir."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Tej czynności nie można cofnąć. Będziesz musiał ponownie zastosować ikony, aby je ponownie zapisać."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا يمكن التراجع عن هذا الإجراء. ستحتاج إلى إعادة تطبيق الأيقونات لتخزينها مؤقتًا مرة أخرى."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การดำเนินการนี้ไม่สามารถย้อนกลับได้ คุณจะต้องใช้ไอคอนใหม่เพื่อแคชอีกครั้ง"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Hành động này không thể hoàn tác. Bạn sẽ cần áp dụng lại biểu tượng để lưu chúng vào bộ nhớ đệm."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tindakan ini tidak dapat dibatalkan. Anda perlu menerapkan ulang ikon untuk menyimpannya kembali ke cache."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Цю дію не можна скасувати. Вам потрібно буде повторно застосувати іконки, щоб кешувати їх знову."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Denna åtgärd kan inte ångras. Du måste tillämpa ikonerna igen för att cacha dem på nytt."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Denne handling kan ikke fortrydes. Du skal genanvende ikoner for at cachelagre dem igen."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Denne handlingen kan ikke angres. Du må bruke ikonene på nytt for å bufre dem igjen."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tätä toimintoa ei voi kumota. Sinun on käytettävä kuvakkeet uudelleen tallentaaksesi ne välimuistiin."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Tuto akci nelze vrátit zpět. Pro opětovné uložení ikon budete muset ikony znovu použít."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Ez a művelet nem vonható vissza. Az ikonokat újra kell alkalmaznia a gyorsítótárazáshoz."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Αυτή η ενέργεια δεν μπορεί να αναιρεθεί. Θα πρέπει να εφαρμόσετε ξανά τα εικονίδια για να τα αποθηκεύσετε."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Această acțiune nu poate fi anulată. Va trebui să reaplicați pictogramele pentru a le stoca din nou în cache."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह क्रिया पूर्ववत नहीं की जा सकती। आइकन को फिर से कैश करने के लिए आपको उन्हें पुनः लागू करना होगा।"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Tindakan ini tidak boleh dibuat asal. Anda perlu menggunakan semula ikon untuk mencachenya semula."
          }
        }
      }
    },
    "This app may be protected by macOS. Try closing the app first, or the app may not support icon changes.": {
      "comment": "Permission error explanation",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese App ist möglicherweise durch macOS geschützt. Versuchen Sie, die App zuerst zu schließen, oder die App unterstützt möglicherweise keine Symboländerungen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta aplicación puede estar protegida por macOS. Intente cerrar la aplicación primero, o la aplicación podría no admitir cambios de icono."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette app est peut-être protégée par macOS. Essayez de la fermer d'abord, ou elle ne prend peut-être pas en charge le changement d'icône."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questa app potrebbe essere protetta da macOS. Prova a chiudere l'app prima, oppure l'app potrebbe non supportare la modifica delle icone."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このアプリは macOS によって保護されている可能性があります。アプリを閉じてから再試行するか、このアプリはアイコンの変更に対応していない可能性があります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 앱은 macOS에 의해 보호되어 있을 수 있습니다. 앱을 먼저 종료하거나, 이 앱은 아이콘 변경을 지원하지 않을 수 있습니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Este aplicativo pode estar protegido pelo macOS. Tente fechar o aplicativo primeiro, ou o aplicativo pode não suportar alterações de ícone."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Это приложение может быть защищено macOS. Попробуйте сначала закрыть приложение, или приложение может не поддерживать изменение значков."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "該應用程式可能受 macOS 保護。請嘗試先關閉該應用程式，或者該應用程式可能不支援更改圖示。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "该应用可能受 macOS 保护。请尝试先关闭该应用，或者该应用可能不支持更改图标。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "該應用程式可能受 macOS 保護。請嘗試先關閉該應用程式，或者該應用程式可能不支援更改圖示。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Deze app is mogelijk beveiligd door macOS. Probeer de app eerst te sluiten, of de app ondersteunt mogelijk geen pictogramwijzigingen."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu uygulama macOS tarafından korunuyor olabilir. Önce uygulamayı kapatmayı deneyin veya uygulama simge değişikliklerini desteklemiyor olabilir."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ta aplikacja może być chroniona przez macOS. Spróbuj najpierw zamknąć aplikację lub aplikacja może nie obsługiwać zmian ikon."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "قد يكون هذا التطبيق محميًا بواسطة macOS. حاول إغلاق التطبيق أولاً، أو قد لا يدعم التطبيق تغيير الأيقونات."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "แอปนี้อาจได้รับการป้องกันโดย macOS ลองปิดแอปก่อน หรือแอปอาจไม่รองรับการเปลี่ยนไอคอน"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Ứng dụng này có thể được bảo vệ bởi macOS. Hãy thử đóng ứng dụng trước, hoặc ứng dụng có thể không hỗ trợ thay đổi biểu tượng."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Aplikasi ini mungkin dilindungi oleh macOS. Coba tutup aplikasi terlebih dahulu, atau aplikasi mungkin tidak mendukung perubahan ikon."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Цей додаток може бути захищений macOS. Спробуйте спершу закрити додаток, або додаток може не підтримувати зміну іконок."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Denna app kan vara skyddad av macOS. Försök stänga appen först, eller så kanske appen inte stöder ikonändringar."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Denne app kan være beskyttet af macOS. Prøv at lukke appen først, eller appen understøtter muligvis ikke ikonændringer."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Denne appen kan være beskyttet av macOS. Prøv å lukke appen først, eller appen støtter kanskje ikke ikonendringer."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tämä sovellus saattaa olla macOS:n suojaama. Yritä sulkea sovellus ensin tai sovellus ei ehkä tue kuvakkeiden vaihtoa."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Tato aplikace může být chráněna systémem macOS. Zkuste nejprve aplikaci zavřít nebo aplikace nemusí podporovat změny ikon."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Ezt az alkalmazást a macOS védheti. Próbálja meg először bezárni az alkalmazást, vagy az alkalmazás nem támogatja az ikonváltoztatást."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Αυτή η εφαρμογή μπορεί να προστατεύεται από το macOS. Δοκιμάστε να κλείσετε πρώτα την εφαρμογή ή η εφαρμογή μπορεί να μην υποστηρίζει αλλαγές εικονιδίων."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Această aplicație poate fi protejată de macOS. Încercați să închideți mai întâi aplicația sau aplicația poate să nu suporte schimbarea pictogramelor."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह ऐप macOS द्वारा सुरक्षित हो सकता है। पहले ऐप बंद करने का प्रयास करें, या ऐप आइकन परिवर्तनों का समर्थन नहीं कर सकता है।"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Apl ini mungkin dilindungi oleh macOS. Cuba tutup apl dahulu, atau apl mungkin tidak menyokong perubahan ikon."
          }
        }
      }
    },
    "This will remove the custom icon and restore the original icon for %@.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dies entfernt das benutzerdefinierte Symbol und stellt das Originalsymbol für %@ wieder her."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto eliminará el icono personalizado y restaurará el icono original de %@."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela supprimera l'icône personnalisée et restaurera l'icône originale pour %@."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo rimuoverà l'icona personalizzata e ripristinerà l'icona originale per %@."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ のカスタムアイコンを削除し、元のアイコンに戻します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@의 사용자 지정 아이콘을 제거하고 원래 아이콘을 복원합니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Isso removerá o ícone personalizado e restaurará o ícone original de %@."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Это удалит пользовательский значок и восстановит оригинальный значок для %@."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "呢個會移除自訂圖像並回復 %@ 嘅原始圖像。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这将移除自定义图标并恢复 %@ 的原始图标。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "這將移除自訂圖像並回復 %@ 的原始圖像。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dit verwijdert het aangepaste pictogram en herstelt het originele pictogram voor %@."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu, özel simgeyi kaldıracak ve %@ için orijinal simgeyi geri yükleyecektir."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Spowoduje to usunięcie niestandardowej ikony i przywrócenie oryginalnej ikony dla %@."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سيؤدي هذا إلى إزالة الأيقونة المخصصة واستعادة الأيقونة الأصلية لـ %@."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การดำเนินการนี้จะลบไอคอนที่กำหนดเองและกู้คืนไอคอนเดิมสำหรับ %@"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Thao tác này sẽ xóa biểu tượng tùy chỉnh và khôi phục biểu tượng gốc cho %@."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Ini akan menghapus ikon kustom dan memulihkan ikon asli untuk %@."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Це видалить користувацьку іконку та відновить оригінальну іконку для %@."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Detta tar bort den anpassade ikonen och återställer originalikonen för %@."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Dette vil fjerne det brugerdefinerede ikon og gendanne det originale ikon for %@."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Dette vil fjerne det tilpassede ikonet og gjenopprette det opprinnelige ikonet for %@."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tämä poistaa mukautetun kuvakkeen ja palauttaa alkuperäisen kuvakkeen sovellukselle %@."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Tím se odebere vlastní ikona a obnoví se původní ikona pro %@."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Ez eltávolítja az egyéni ikont és visszaállítja az eredeti ikont a(z) %@ alkalmazáshoz."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Αυτό θα αφαιρέσει το προσαρμοσμένο εικονίδιο και θα επαναφέρει το αρχικό εικονίδιο για %@."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Aceasta va elimina pictograma personalizată și va restaura pictograma originală pentru %@."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ के लिए कस्टम आइकन हटाया जाएगा और मूल आइकन पुनर्स्थापित किया जाएगा।"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Ini akan mengalih keluar ikon tersuai dan memulihkan ikon asal untuk %@."
          }
        }
      }
    },
