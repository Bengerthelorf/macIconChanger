    "1. A dialog will appear requesting access to /Applications": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "1. Ein Dialog wird erscheinen, der Zugriff auf /Applications anfordert"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "1. Aparecerá un diálogo solicitando acceso a /Applications"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "1. Une boîte de dialogue demandant l'accès à /Applications apparaîtra"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "1. Apparirà una finestra di dialogo che richiede l'accesso a /Applications"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "1. /Applicationsへのアクセスを要求するダイアログが表示されます"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "1. /Applications 접근을 요청하는 대화 상자가 나타납니다"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "1. Uma janela aparecerá solicitando acesso a /Applications"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "1. Появится диалог с запросом доступа к /Applications"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "1. 將會出現要求取用 /Applications 的對話框"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "1. 将会出现一个请求访问 /Applications 目录的对话框"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "1. 將會出現要求取用 /Applications 的對話框"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "1. Er verschijnt een dialoogvenster om toegang tot /Applications te vragen"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "1. /Applications klasörüne erişim isteyen bir iletişim kutusu görünecektir"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "1. Pojawi się okno dialogowe z prośbą o dostęp do /Applications"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "1. سيظهر مربع حوار يطلب الوصول إلى /Applications"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "1. จะมีกล่องโต้ตอบปรากฏขึ้นเพื่อขอสิทธิ์เข้าถึง /Applications"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "1. Một hộp thoại sẽ xuất hiện yêu cầu quyền truy cập /Applications"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "1. Dialog akan muncul meminta akses ke /Applications"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "1. З'явиться діалогове вікно із запитом доступу до /Applications"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "1. En dialogruta visas som begär åtkomst till /Applications"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "1. En dialogboks vil vises, der anmoder om adgang til /Applications"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "1. En dialogboks vil vises som ber om tilgang til /Applications"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "1. Näyttöön tulee valintaikkuna, joka pyytää pääsyä /Applications-kansioon"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "1. Zobrazí se dialogové okno s žádostí o přístup k /Applications"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "1. Megjelenik egy párbeszédablak, amely hozzáférést kér a /Applications mappához"
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "1. Θα εμφανιστεί ένα παράθυρο διαλόγου που ζητά πρόσβαση στο /Applications"
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "1. Va apărea o fereastră de dialog care solicită acces la /Applications"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "1. /Applications तक पहुंच का अनुरोध करने वाला एक डायलॉग दिखाई देगा"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "1. Dialog akan muncul meminta akses ke /Applications"
          }
        }
      }
    },
    "2. Please choose /Applications and click OK": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "2. Bitte wählen Sie /Applications und klicken Sie auf OK"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "2. Por favor seleccione /Applications y haga clic en OK"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "2. Veuillez choisir /Applications et cliquer sur OK"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "2. Seleziona /Applications e fai clic su OK"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "2. /Applicationsを選択し、「OK」をクリックしてください"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "2. /Applications를 선택하고 확인을 클릭하세요"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "2. Por favor selecione /Applications e clique em OK"
          }
        },
        "ru": {
