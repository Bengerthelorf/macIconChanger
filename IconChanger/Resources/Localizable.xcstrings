        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "將圖像套用到 App 時會自動快取"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Pictogrammen worden automatisch opgeslagen wanneer u ze op apps toepast"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Simgeler uygulamalara uygulandığında otomatik olarak önbelleğe alınır"
